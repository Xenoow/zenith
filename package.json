{
  "name": "zenith",
  "productName": "Zenith",
  "version": "1.0.0",
  "description": "Zenith — Planifiez vos journées, gagnez de l'XP.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/generate-icons.js",
    "build": "npm run icons && electron-builder --win",
    "build:dir": "npm run icons && electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.zenith.planner",
    "productName": "Zenith",
    "copyright": "© 2026 Zenith",
    "afterPack": "./scripts/after-pack.js",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,*.map}",
      "!node_modules/**/test{s,}/**",
      "!dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zenith",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "Xenoow",
      "repo": "zenith"
    }
  }
}
